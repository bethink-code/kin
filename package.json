{
  "name": "kin",
  "version": "0.1.0",
  "description": "A personal financial story app that helps South Africans build, understand, and act on their financial situation.",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "kill-port 5000 5173",
    "dev:server": "npx tsx server/index.ts",
    "dev:client": "wait-on tcp:5000 && npx vite",
    "dev": "doppler run -- concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "build:api": "esbuild server/api.ts --platform=node --packages=external --bundle --format=esm --outfile=api/index.mjs",
    "db:push": "doppler run -- drizzle-kit push",
    "seed:admin": "doppler run -- npx tsx scripts/seed-admin.ts",
    "seed:prompts": "doppler run -- npx tsx scripts/seed-prompts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@neondatabase/serverless": "^0.10.4",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@tanstack/react-query": "^5.59.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.0",
    "drizzle-zod": "^0.5.1",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "lucide-react": "^0.453.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "wouter": "^3.3.5",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0-beta.4",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.7.5",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.11.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.28.0",
    "esbuild": "^0.24.0",
    "kill-port": "^2.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0-beta.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "wait-on": "^8.0.1"
  }
}
